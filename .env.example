# Example environment for the Hermes Meshtastic adapter.
# Copy to .env and adjust for your gateway node and mesh.
#   cp .env.example .env

# Required. Serial path to the gateway Meshtastic node, or "auto" to discover.
# macOS:  /dev/cu.usbserial-0001  or  /dev/cu.usbmodem*
# Linux:  /dev/ttyUSB0            or  /dev/ttyACM0
MESHTASTIC_SERIAL_PORT=/dev/cu.usbserial-0001

# Optional. Serial baud rate (default: 115200).
#MESHTASTIC_BAUD_RATE=115200

# Optional. Connect to a WiFi/Ethernet node over TCP/IP instead of serial.
# When MESHTASTIC_TCP_HOST is set, serial is ignored (one transport at a time).
#MESHTASTIC_TCP_HOST=192.168.1.50
#MESHTASTIC_TCP_PORT=4403

# Optional. Comma-separated node IDs allowed to talk to Hermes.
# Leave empty (and ALLOW_ALL_USERS unset) to deny all nodes by default.
MESHTASTIC_ALLOWED_NODES=!da1b1613

# Optional. Allow ANY node on the mesh to talk to Hermes. Use with caution.
#MESHTASTIC_ALLOW_ALL_USERS=false

# Optional. Answer channel/broadcast messages too (agent replies into the shared
# channel). Off by default so the agent responds only to direct messages.
#MESHTASTIC_ALLOW_CHANNELS=false

# Optional. Default delivery target for cron/notification jobs.
# e.g. meshtastic:!da1b1613  or  meshtastic:channel:0
MESHTASTIC_HOME_CHANNEL=meshtastic:!da1b1613

# Optional. Max UTF-8 bytes per outbound LoRa chunk (default: 170).
# 170 is conservative for multi-hop reliability and leaves headroom for
# encrypted-DM (PKI) overhead; the raw protocol payload ceiling is 233.
MESHTASTIC_CHUNK_BYTES=170

# Optional. Delay in seconds between chunk sends (default: 4.0).
MESHTASTIC_CHUNK_DELAY=4.0

# Optional. Seconds to wait for ACK/NACK per outbound chunk (default: 0).
# 0 is non-blocking; set e.g. 30 to fail sends on NAK or timeout.
MESHTASTIC_ACK_TIMEOUT=0

# Optional. Extra delivery attempts for un-ACKed DIRECT-MESSAGE chunks (default: 0).
# >0 implies waiting for the ACK. Transient failures (timeout/no-route) are
# re-sent; permanent ones (TOO_LARGE, etc.) are not; broadcasts are never retried.
#MESHTASTIC_SEND_RETRIES=3
# Optional. Seconds between delivery retries (default: 5.0).
#MESHTASTIC_RETRY_BACKOFF=5.0
# Optional. Age in days at which persisted telemetry/position/signal rows are
# pruned from SQLite (default: 30). 0 disables pruning.
#MESHTASTIC_TELEMETRY_RETENTION_DAYS=30
